@{
    ViewData["Title"] = "Calendario Colaborativo";
}

<h2 class="text-center mb-4">📅 Calendario Colaborativo</h2>
<div id="calendar"></div>

<!-- Modal para crear evento -->
<div class="modal fade" id="eventoModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Nuevo Evento</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>

            <div class="modal-body">

                <div class="mb-3">
                    <label for="txtTitulo" class="form-label">Título</label>
                    <input type="text" class="form-control" id="txtTitulo" required />
                </div>

                <div class="mb-3">
                    <label for="txtDescripcion" class="form-label">Descripción</label>
                    <textarea class="form-control" id="txtDescripcion" rows="2"></textarea>
                </div>

                <div class="mb-3">
                    <label for="txtHoraInicio" class="form-label">Hora inicio</label>
                    <input type="time" class="form-control" id="txtHoraInicio" required />
                </div>

                <div class="mb-3">
                    <label for="txtHoraFin" class="form-label">Hora fin</label>
                    <input type="time" class="form-control" id="txtHoraFin" required />
                </div>

                <div class="mb-3">
                    <label for="txtColor" class="form-label">Color</label>
                    <input type="color" class="form-control form-control-color" id="txtColor" value="#3788d8" />
                </div>

                <input type="hidden" id="txtFechaInicio" />
                <input type="hidden" id="txtFechaFin" />

            </div>

            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancelar</button>
                <button type="button" class="btn btn-primary" id="btnGuardar">Guardar</button>
            </div>
        </div>
    </div>
</div>

<!-- Modal para ver detalle del evento -->
<div class="modal fade" id="detalleEventoModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Detalle del Evento</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>

            <div class="modal-body">
                <p><strong>Título:</strong> <span id="detalleTitulo"></span></p>
                <p><strong>Descripción:</strong> <span id="detalleDescripcion"></span></p>
                <p><strong>Inicio:</strong> <span id="detalleInicio"></span></p>
                <p><strong>Fin:</strong> <span id="detalleFin"></span></p>
                <p>
                    <strong>Color:</strong>
                    <span id="detalleColorTexto"></span>
                    <span id="detalleColorMuestra"
                          style="display:inline-block; width:18px; height:18px; border-radius:50%; margin-left:8px; border:1px solid #ccc; vertical-align:middle;">
                    </span>
                </p>
            </div>

            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cerrar</button>
            </div>
        </div>
    </div>
</div>

<!-- Toast de éxito -->
<div class="toast-container position-fixed bottom-0 end-0 p-3">
    <div id="toastExito" class="toast align-items-center text-bg-success border-0" role="alert" aria-live="assertive" aria-atomic="true">
        <div class="d-flex">
            <div class="toast-body">
                ✅ Evento creado exitosamente.
            </div>
            <button type="button" class="btn-close btn-close-white me-2 m-auto" data-bs-dismiss="toast"></button>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/jquery@3.7.1/dist/jquery.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/fullcalendar@6.1.15/index.global.min.js"></script>

    <script>
        $(document).ready(function () {

            var eventoModalEl = document.getElementById('eventoModal');
            var eventoModal = new bootstrap.Modal(eventoModalEl);

            var detalleEventoModalEl = document.getElementById('detalleEventoModal');
            var detalleEventoModal = new bootstrap.Modal(detalleEventoModalEl);

            var toastExito = new bootstrap.Toast(document.getElementById('toastExito'));

            var calendarEl = document.getElementById('calendar');

            var calendar = new FullCalendar.Calendar(calendarEl, {
                initialView: 'dayGridMonth',
                locale: 'es',
                firstDay: 1,
                selectable: true,
                editable: true,

                headerToolbar: {
                    left: 'prev,next today',
                    center: 'title',
                    right: 'dayGridMonth,timeGridWeek,timeGridDay'
                },

                // CARGA DE EVENTOS
                events: function (info, successCallback, failureCallback) {
                    $.ajax({
                        url: '@Url.Action("GetEvents", "Calendar")',
                        type: 'GET',
                        data: {
                            start: info.startStr,
                            end: info.endStr
                        },
                        success: successCallback,
                        error: function () {
                            alert("Error al cargar los eventos.");
                            failureCallback();
                        }
                    });
                },

                // SELECCIÓN DE RANGO
                select: function (info) {
                    $('#txtFechaInicio').val(info.startStr);
                    $('#txtFechaFin').val(info.endStr);

                    $('#txtTitulo').val('');
                    $('#txtDescripcion').val('');
                    $('#txtHoraInicio').val("09:00");
                    $('#txtHoraFin').val("10:00");
                    $('#txtColor').val('#3788d8');

                    eventoModal.show();
                },

                // CLICK EN DÍA VACÍO
                dateClick: function (info) {
                    $('#txtFechaInicio').val(info.dateStr);
                    $('#txtFechaFin').val(info.dateStr);

                    $('#txtTitulo').val('');
                    $('#txtDescripcion').val('');
                    $('#txtHoraInicio').val("09:00");
                    $('#txtHoraFin').val("10:00");
                    $('#txtColor').val('#3788d8');

                    eventoModal.show();
                },

                // CLICK EN EVENTO
                eventClick: function (info) {
                    info.jsEvent.preventDefault();

                    var evento = info.event;

                    var titulo = evento.title || 'Sin título';
                    var descripcion = evento.extendedProps.description || 'Sin descripción';
                    var inicio = evento.start ? evento.start.toLocaleString() : 'Sin fecha';
                    var fin = evento.end ? evento.end.toLocaleString() : 'Sin fecha';
                    var color = evento.backgroundColor || evento.extendedProps.color || '#3788d8';

                    $('#detalleTitulo').text(titulo);
                    $('#detalleDescripcion').text(descripcion);
                    $('#detalleInicio').text(inicio);
                    $('#detalleFin').text(fin);
                    $('#detalleColorTexto').text(color);
                    $('#detalleColorMuestra').css('background-color', color);

                    detalleEventoModal.show();
                }
            });

            calendar.render();

            // GUARDAR EVENTO
            $('#btnGuardar').on('click', function () {

                var $btn = $(this);
                if ($btn.prop('disabled')) return;

                var titulo = $('#txtTitulo').val();
                if (!titulo) {
                    alert("El título es obligatorio.");
                    return;
                }

                var inicioCompleto = $('#txtFechaInicio').val() + "T" + $('#txtHoraInicio').val();
                var finCompleto = $('#txtFechaFin').val() + "T" + $('#txtHoraFin').val();

                var evento = {
                    Titulo: titulo,
                    Descripcion: $('#txtDescripcion').val(),
                    FechaInicio: inicioCompleto,
                    FechaFin: finCompleto,
                    Color: $('#txtColor').val()
                };

                $btn.prop('disabled', true);

                $.ajax({
                    url: '@Url.Action("CreateEvent", "Calendar")',
                    type: 'POST',
                    contentType: 'application/json',
                    data: JSON.stringify(evento),
                    success: function (resp) {
                        if (resp.success) {
                            calendar.refetchEvents();
                            eventoModal.hide();
                            toastExito.show();
                        } else {
                            alert(resp.message);
                        }
                    },
                    error: function () {
                        alert("Error al guardar el evento.");
                    },
                    complete: function () {
                        $btn.prop('disabled', false);
                    }
                });
            });
        });
    </script>
}